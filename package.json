{
  "name": "uber",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev.sh",
    "frontend:install": "npm --prefix delivery-frontend install",
    "frontend:dev": "npm --prefix delivery-frontend run dev",
